parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - src/Resources
    ignoreErrors:
        # Shopware Plugin lifecycle: $this->container is nullable by interface but always set at runtime
        -
            identifier: method.nonObject
            path: src/MmdEmptyCategory.php
        # Shopware Plugin lifecycle: container->get() returns object, repository methods not inferable
        -
            identifier: method.notFound
            path: src/MmdEmptyCategory.php
